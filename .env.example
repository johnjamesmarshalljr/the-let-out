# Copy this file to .env.local and fill in the two values from your Supabase project.
# Settings > API in the Supabase dashboard.
# Both are safe to expose in the browser — your data is protected by Row Level Security.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
